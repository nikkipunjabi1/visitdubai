# This is Dubai — environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Get credentials from your CMS instance: Settings → API Keys (create an API key).

# --- Required ---

# Base URL of your CMS instance (e.g. https://example.cms.optimizely.com/)
OPTIMIZELY_CMS_URL=

# CLI client credentials — used to sync content types to the CMS (config push).
# Create in: CMS → Settings → API Keys → Create API key
OPTIMIZELY_CMS_CLIENT_ID=
OPTIMIZELY_CMS_CLIENT_SECRET=

# Content Graph single key — public, read-only delivery key (frontend-safe).
# Found in: CMS → Settings → API Keys
OPTIMIZELY_GRAPH_SINGLE_KEY=

# --- Optional / environment-specific ---

# Content Graph endpoint. Production default: https://cg.optimizely.com/content/v2
# Test (cmstest) environment: https://staging.cg.optimizely.com/
OPTIMIZELY_GRAPH_GATEWAY=

# Public host of this app — enables static generation of pages in [...slug].
# e.g. https://this-is-dubai.vercel.app  (leave blank for pure on-demand rendering)
APPLICATION_HOST=

# Global search-indexing switch. DEFAULT OFF (unset/false) so the demo is NOT crawled:
# robots.txt disallows all + pages are served noindex. Set to "true" ONLY for a real launch.
# (Can also be controlled from the CMS via SiteSettings.allowSearchIndexing.)
SITE_INDEXABLE=false

# For the cmstest environment ONLY: use these instead of OPTIMIZELY_CMS_URL
# OPTIMIZELY_CMS_API_URL=https://api.cmstest.optimizely.com

# Preview-before-publish module (Phase 3) — signing secret for shareable preview links.
# PREVIEW_SIGNING_SECRET=

# Feature Experimentation (optional, later)
# OPTIMIZELY_FX_SDK_KEY=
# OPTIMIZELY_FX_ACCESS_TOKEN=
